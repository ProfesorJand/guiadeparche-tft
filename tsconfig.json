{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@assets/*": ["src/assets/*"],
      "@stores/*": ["src/stores/*"],
      "@layouts/*":["src/layouts/*"],
      "@json/*":["src/json/*"],
      "@functions/*":["src/functions/*"],
      "@spotify-data":["spotify-data.json"],
      "@spotify-data-global":["spotify-data-global.json"],
      "@spotify-data-global-music":["spotify-data-global-music.json"],
    }
  }
}