---
import Header from '../components/headers/Header.astro';
import Footer from '../components/footer/Footer.astro';
import Logo from '../components/logo/Logo.astro';
import logoGP from "src/assets/GP_logo.png";
import Adsense from '../components/adsense/Adsense.jsx';
import { ViewTransitions } from 'astro:transitions';
import PageLoader from '@components/PageLoader';
import Youtube from '@components/youtube/Youtube.jsx';
const admin = typeof window !== "undefined" ? window.localStorage.getItem("gp_admin") : false;
interface Props {
  title: string;
  JSONSchema?: string; 
  description?: string | string[];
  keywords?: string;
  image?: string;
  canonical?: string;
  hide?:boolean;
  snippetImgUrl?: string;
}
const { title, JSONSchema, description, keywords, image, canonical, hide=false, snippetImgUrl } = Astro.props;

// Si no se define snippetImgUrl, usamos image o la ruta por defecto del logo en la carpeta public
const resolvedSnippetImgUrl = snippetImgUrl || image || "/web/logoGP2026.png";
const absoluteSnippetImgUrl = new URL(resolvedSnippetImgUrl, Astro.site || "https://guiadeparche.com").href;

---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- google search console -->
    {!admin && <meta name="google-site-verification" content="VXzuc6CSTiTOeduk03n_uh0IUkgaBHkJAhQdtam2md0" />}
    <!-- google analitics -->
    {!admin && 
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-69PWGWV8LZ"></script>
    <script>
      declare global {
        interface Window {
          dataLayer: any[];
          gtag: (...args: any[]) => void; 
        }
      }
      window.dataLayer = window.dataLayer || [];
      window.gtag = function gtag(){window.dataLayer.push(arguments);}  // Añadir gtag a window
      window.gtag('js', new Date());

      window.gtag('config', 'G-69PWGWV8LZ');
    </script>
    }
    <!-- google ads dynamically loaded (no ads for admin) -->
    <script is:inline>
      (function() {
        var isAdmin = false;
        try {
          var savedUser = localStorage.getItem('gp_user');
          if (savedUser) {
            isAdmin = !!JSON.parse(savedUser).isAdmin;
          } else {
            isAdmin = localStorage.getItem('gp_admin') === 'true';
          }
        } catch (e) {}

        if (!isAdmin) {
          // google ads mobile
          var ampAdScript = document.createElement('script');
          ampAdScript.async = true;
          ampAdScript.setAttribute('custom-element', 'amp-ad');
          ampAdScript.src = "https://cdn.ampproject.org/v0/amp-ad-0.1.js";
          document.head.appendChild(ampAdScript);

          // google ads
          var adsScript = document.createElement('script');
          adsScript.async = true;
          adsScript.crossOrigin = "anonymous";
          adsScript.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6116944495372863";
          document.head.appendChild(adsScript);
        }
      })();
    </script>
    <link rel="icon" type="image/webp" href={"/web/logoGP2026.webp"} />
    <!-- <link rel="icon" type="image/png" href={"/web/logo-gp-2026.png"} /> -->
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="author" content="Jupeson, Profesorjand"/>
    {description && <meta name="description" content={Array.isArray(description) ? description[0] : description}/>} 
    {keywords && <meta name="keywords" content={keywords} />}

    {/* debe verificar si al final del string de canonical termina con / y si no lo tiene agregarlo */}
    {canonical && <link rel="canonical" href={canonical.endsWith("/") ? canonical : canonical + "/"} />}
    {absoluteSnippetImgUrl && <meta property="og:image" content={absoluteSnippetImgUrl} />}

     <!-- Schema Script -->
    {JSONSchema && <script type="application/ld+json" set:html={JSONSchema}></script>}

    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <PageLoader client:only="react" />
    <div class="bodyLayout">
      <header class="bodyHeader">
        <Logo></Logo>
        <Header transition:persist/>
      </header> 
      <main class="bodyMain">
          <slot></slot>
      </main>
      <footer class="bodyFooter">
        <Footer></Footer>
      </footer>
    </div>
    <script>
      // Detectar Ctrl + Alt + A
      document.addEventListener('keydown', (e) => {
        if (e.ctrlKey && e.altKey && e.key.toLowerCase() === 'a') {
          const isLocalhost = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
          const port = location.port || '4321'; // cambiá este si usás otro puerto

          const adminURL = isLocalhost
            ? `http://localhost:${port}/admin`
            : 'https://guiadeparche.com/admin';

          window.location.href = adminURL;
        }
      });
    </script>
  </body>
</html>

<style is:global>

  :root {
    --bg-primary-rgb: 14 3 65;
    --bg-primary: #0e0341;
    --bg-secondary: #0f0b5a;
    --bg-text-color: #101525;
    --bg-tertiary: #120d69;
    --bg-main: #0c023a;
    --bg-hover:#1d15aa;
    --bg-main-secondary:#191f33;
    --bg-purple-primary:#321139;
    --bg-purple-hover-primary:#4d1657;
    --bg-purple-secondary:#6b2273;
    --bg-purple-hover-secondary:#5a1b63;
    --bg-primary-solid:#12182c;
    --color-primary: #cfcfcf;
    --color-white:#cfcfcf;
    --color-black:#1f1f1f;
    --border-color: grey;
    --border-gray-color: grey;
    --text-color-white-primary: #e5e5e5;
    --text-color-white-secondary: #e5e5e5;
    --link-color-primary:brown;
    --link-color-secondary:rgb(105, 27, 27);
    --width-main: 100%;
    --height-header: 8vh;
    --height-footer: 20vh;
    --number-champ-meta: calc(100%/6);
    --accent: 136, 58, 234;
    --accent-light: 224, 204, 250;
    --accent-dark: 49, 10, 101;
    --accent-gradient: linear-gradient(
      45deg,
      rgb(var(--accent)),
      rgb(var(--accent-light)) 30%,
      white 60%
    );
    font-family: Sans-serif;
    color: var(--text-color-white-primary);
  }

  @font-face {
    font-family: 'RIOTJinx'; /* Name your font family */
    src: url('/fonts/RIOTJinx.otf') format("opentype"); /* Locate the .ttf file within your directory*/
  }

  @font-face {
    font-family: 'ObviouslyWideBoldItalic'; /* Nombre corregido */
  src: url('/fonts/ObviouslyWide-BoldItalic.otf') format("opentype");
  font-weight: normal;
  font-style: normal;
  font-display: swap; /* Ayuda a que se cargue mejor para capturas */
  }

  @font-face {
    font-family: 'ObvioslyWideBold'; /* Name your font family */
    src: url('/fonts/ObviouslyWide-Bold.otf') format("opentype"); /* Locate the .ttf file within your directory*/
  }

  @font-face {
  font-family: "Fatal Fighter";
  src: url("/fonts/Fatal Fighter.otf") format("truetype");
  font-weight: normal;
  font-style: normal;
}

/* 
  @font-face {
    font-family: 'MiFuente';
    src: url('/fonts/MiFuente.woff2') format('woff2');
    font-weight: normal;
    font-style: normal;
  } */

  html {
  background: transparent;
  scroll-behavior: smooth;
}

  [id] {
    scroll-margin-top: calc(var(--height-header) + 20px);
  }

  body::-webkit-scrollbar {
    width: 12px; /* width of the entire scrollbar */
    background: transparent;
  }

  body::-webkit-scrollbar-track {
    /* background: var(--bg-primary); */
    background: transparent;
    background-repeat: no-repeat;
    background-size: cover;
    background-attachment: fixed;
    background-position: center;
    box-shadow: none;
  }

  body::-webkit-scrollbar-thumb {
    background-color: blue; /* color of the scroll thumb */
    border-radius: 20px; /* roundness of the scroll thumb */
    border: 2px solid var(--border-color); /* creates padding around scroll thumb */
    background-clip: padding-box;
  }
  body {
    background-color: var(--bg-primary);
    overflow-y: scroll;
    margin: 0;
    padding: 0;
    width: 100vw;
    max-width: 100%;
    display: flex;
    position: relative;
    flex-direction: column;
    min-height: 100vh;
    background-color: #191f32;
    /* background-image: radial-gradient(circle, #000000 1px, transparent 1px);
    background-size: 4px 4px; */
    opacity: 1;
  }
  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }
  .midSection{
    display:flex;
    position: relative;
    flex-direction: row;
    width: 100%;
  }
  .hide {
    display: none;
  }
  h1{
    text-align: center;
    text-decoration: underline var(--border-color);
    font-size: 2rem;
  }
  h2{
    text-align: center;
  }
  .adsbygoogle{
    z-index: 1 !important;
  }
  #google-anno-sa{
    display: none;
  }
  html body .google-anno-skip.google-anno-sc {
    display: none !important;
  }
  a{
    color: var(--color-white)
  }


  @media only screen and (max-width: 900px) {
    .bodyLayout{
      display: flex;
      position: relative;
      width: 100%;
      flex-direction: column;
    }
    .bodyHeader{
      display: flex;
      position: sticky;
      z-index: 9;
      top:0;
      width: 100%;
      max-width: 100%;
      height: var(--height-header);
      flex-direction: row;
      background-color: #191f32;
      /* background-image: radial-gradient(circle, #000000 1px, transparent 1px);
      background-size: 4px 4px;
      opacity: 1; */
    }
    .bodyInfo{
      display: flex;
      width: 100vw;
      max-width: 100%;
      position: relative;
      flex-direction: column;
      height: 100%;
      min-height: 92vh;
    }
    .bodyAside{
      display: none;
      width: 100%;
      height: 100vh !important;
      overflow: hidden;
      /* background-color: aqua; */
    }
    .bodyMain{
      display: flex;
      width: 100%;
      position: relative;
      flex-direction: column;
      background-color: #101525;
      /* background-image: radial-gradient(circle, #000000 1px, transparent 1px);
      background-size: 4px 4px;
      opacity: 1; */
      padding: 5px;
      box-sizing: border-box;
    }
    .bodyFooter{
      display: flex;
      position: relative;
      justify-content: center;
      width: 100vw;
      max-width: 100%;
      /* height: var(--height-footer); */
      /* bottom:0; */
    }
    main{
      width: 100%;
    }
    .midSection{
      display:flex;
      position: relative;
      flex-direction: column;
    }
    h1, h2, h3, h4{
      font-size: 1rem;
    }
  }

  @media only screen and (min-width:900px) {
    .bodyLayout{
      display: flex;
      position: relative;
      margin:0;
      width: 100%;
      max-width: 100%;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      box-sizing: border-box;
      /* padding-bottom: var(--height-footer); */
    }
    .bodyHeader{
      display: flex;
      position: sticky;
      z-index: 9;
      top:0;
      width: 100%;
      max-width: 100%;
      height: var(--height-header);
      flex-direction: row;
      background-color: #191f32;
      /* background-image: radial-gradient(circle, #000000 1px, transparent 1px);
      background-size: 4px 4px; */
      opacity: 1;
      padding: 0 2rem;
      box-sizing: border-box;
    }
    .bodyInfo{
      display: flex;
      width: 100%;
      max-width: 100%;
      position: relative;
      flex-direction: row;
      height: 100%;
      min-height: 92vh;
      /* background-color: #ffd700; */
    }
    .bodyMain{
      display: flex;
      width: 100%;
      position: relative;
      flex-direction: column;
      background-color: var(--bg-primary-solid);
      padding:2rem;
      box-sizing: border-box;
      /* background-color: #101525;
      background-image: radial-gradient(circle, #000000 1px, transparent 1px);
      background-size: 4px 4px;
      opacity: 1; */
    }
    .bodyFooter{
      display: flex;
      position: relative;
      justify-content: center;
      width: 100%;
      max-width: 100%;
    }
  }
</style>