---
import PlatformStreamer from "./PlatformStreamer2"
import SocialIcon from "../icons/SocialIcon.astro"
---

<div class="footerContainer">
  <div class="footerContainerVideo">
    <PlatformStreamer client:only="react"/>
    <!-- <Twitch client:only="react"/> -->
     <!-- <Kick client:only="react"/> -->
  </div>
  <div class="footerContainerInfo">
     <div class="footerExtra">
      <p>© 2026 GUIADEPARCHE</p>
      <ul class="extraLinks">
        <li><a href="https://guiadeparche.com/terminos-y-condiciones/" target="_blank">Términos y Condiciones</a></li>
        <li><a href="https://guiadeparche.com/politica-de-privacidad/" target="_blank">Política de privacidad</a></li>
      </ul>
    </div>
    <div class="infoMediaContainer">
      <p>REDES SOCIALES</p>
      <div class="infoMedia">
        <p class="footerTitulo">GUIADEPARCHE:</p>
        <ul class="socialList">
          <li class="socialIconLink">
            <a href="https://www.instagram.com/guiadeparche/" target="_blank" aria-label="Instagram"><SocialIcon name="instagram" height="1rem"/></a>
          </li>
          <li class="socialIconLink">
            <a href="https://x.com/guiadeparche" target="_blank" aria-label="Twitter"><SocialIcon name="twitter" height="1rem" /></a>
          </li>
          <li class="socialIconLink">
            <a href="https://www.discord.gg/F8rsQrx" target="_blank" aria-label="Discord"><SocialIcon name="discord" height="1rem"/></a>
          </li>
          <!-- <li class="socialIconLink">
            <a href="https://www.linkedin.com/in/profesorjand/" target="_blank" aria-label="LinkedIn"><SocialIcon name="linkedin" height="1rem"/></a>
          </li> -->
        </ul>
      </div>
      <div class="infoMedia" style="align-items: center;">

        <p class="footerTitulo">JUPESON:</p>
        <ul class="socialList">
          <li class="socialIconLink">
            <a href="https://twitch.tv/jupeson" target="_blank" aria-label="Twitch"><SocialIcon name="twitch" height="1rem" /></a>
          </li>
          <li class="socialIconLink">
            <a href="https://www.youtube.com/jupeson" target="_blank" aria-label="Youtube"><SocialIcon name="youtube" height="1rem" /></a>
          </li>
          <li class="socialIconLink">
            <a href="https://www.instagram.com/jupeson/" target="_blank" aria-label="Instagram"><SocialIcon name="instagram" height="1rem" /></a>
          </li>
          <li class="socialIconLink">
            <a href="https://x.com/jupeson" target="_blank" aria-label="Twitter"><SocialIcon name="twitter" height="1rem" /></a>
          </li>
          <li class="socialIconLink">
            <a href="https://www.tiktok.com/@jupeson" target="_blank" aria-label="TikTok"><SocialIcon name="tiktok" height="1rem" /></a>
          </li>
          <li class="socialIconLink">
            <a href="https://www.facebook.com/jupesongaming" target="_blank" aria-label="Facebook"><SocialIcon name="facebook" height="1rem" /></a>
          </li>
        </ul>
      </div>
    </div>
   
</div>

<style>
  .footerContainer {
    justify-content: center;
    align-items: center;
    width: var(--width-main);
    max-width:1200px;
    flex-direction: row;
    display: flex;
    position: relative;
    box-sizing: border-box;
    gap:5px;
    padding:5px;
    /* height: 100%; */
    /* background-color: #12182c;
      background-image: radial-gradient(circle, #000000 1px, transparent 1px);
      opacity: 1; */

  }
  article{
    display: flex;
    flex-direction: column;
    position:relative;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
  }
  .footerContainerVideo{
    display:flex;
    flex-direction: column;
    width:calc((100% - 5px) / 12 * 3);
  }
  .footerContainerInfo{
    display: flex;
    flex-direction: row;
    width:calc((100% - 5px) / 12 * 9);
    height: 100%;
    gap:1rem;
    padding:1rem;
  }
  .footerContainerInfo p{
    margin: 0;
  }
  .footerContainerInfo a{
    color: #6672b1;
  }
  /* .footerContainerInfo a:visited{
    color:var(--link-color-secondary)
  } */
   .infoMediaContainer{
    display:flex;
    flex-direction: column;
    gap:1rem;
    flex:1;
    align-items: center;
    border: 2px solid rgba(255, 255, 255, 0.185);
    box-sizing: border-box;
    padding:1rem;
    border-radius: 1rem;
   }
  .infoMedia{
    display:flex;
    flex-direction:row;
    gap:5px;
    flex-wrap: wrap;
    text-align: left;
    align-self: flex-start;
    align-items: center;
    justify-content: center;
  }
  .socialList {
    display: flex;
    flex-direction: row;
    gap: 15px;
    padding-inline-start: 0;
    list-style: none;
    margin: 5px 0;
    align-items: center;
  }
  .socialIconLink a {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-color-white-primary, #cfcfcf);
    transition: color 0.3s ease, transform 0.3s ease;
    /* Usamos font-size para controlar el tamaño base si queremos */
    font-size: 1.2rem;
  }
  /* Forzamos que el SVG tome el tamaño relativo al texto usando "em" */
  .socialIconLink a svg {
    height: 1em;
    width: 1em;
  }
  .socialIconLink a:hover {
    color: white;
    transform: scale(1.15);
  }
  .footerExtra {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex:1;
    border: 2px solid rgba(255, 255, 255, 0.185);
    box-sizing: border-box;
    padding:1rem;
    border-radius: 1rem;
  }
  .extraLinks {
    display: flex;
    flex-direction: column;
    gap: 15px;
    align-self: flex-start;
  }
  @media only screen and (max-width:900px) {
    .footerContainer {
    justify-content: center;
    align-items: center;
    width: 100%;
    flex-direction: column;
    display: flex;
    position: relative;
    box-sizing: border-box;
    gap:5px;
    padding:5px;
    /* height: 100%; */

  }
  .footerContainerInfo{
    width: 100%;
  }
  }
</style>
