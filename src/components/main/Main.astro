---
const { backgroundColor = "var(--bg-main)" } = Astro.props;
---
<main>
    <slot/>
</main>

<style define:vars={{ backgroundColor }}>
    main {
        width: 100%;
        max-width: 100%;
        font-size: 20px;
        line-height: 1.6;
        box-sizing: border-box;
      }
    @media only screen and (min-width: 900px) {
        main {
            padding: 0 2rem 2rem 2rem;
        }
   }
</style>