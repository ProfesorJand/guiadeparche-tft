---
import LayoutMaxWidth from "@layouts/LayoutMaxWidth.astro";
import VideoComponent from "@components/youtube/VideoComponent.jsx";
import CardsCompos from "@components/TFT/CardsCompos";
interface Props {
  titleMain?: string;
  titleHighlight?: string;
  description?: string;
  lastUpdate?: string;
  video: { id: string; title: string; thumbnail: string };
  top10Comps: any[];
  restComps:any[];
  activeId?: string;
}

const {
  titleMain = "TFT META COMPS",
  titleHighlight = "TIER LIST - PATCH 17.3",
  description = "Las mejores composiciones del Set 17 actualizadas para el parche 17.3. Aprende cuándo jugarlas, como posicionar y qué objetos usar para subir de elo más rápido en Teamfight Tactics.",
  lastUpdate = "14 de Julio de 2026 - Parche 17.3",
  video,
  top10Comps,
  restComps = [],
  activeId = null,
} = Astro.props;

const tiersInfo = [
  {
    tier: "S",
    title: "Meta Definitivo",
    text: "Las composiciones más fuertes, estables y consistentes del meta actual. ",
  },
  {
    tier: "A",
    title: "Muy Fuertes",
    text: "Composiciones sólidas y confiables, excelentes opciones para subir de elo.",
  },
  {
    tier: "B",
    title: "Sólidas",
    text: "Opciones viables que pueden funcionar bien si las condiciones son favorables.",
  },
  {
    tier: "C",
    title: "Situacionales",
    text: "Composiciones situacionales o que requieren una ejecución más precisa. ",
  },
];
---

<LayoutMaxWidth>
  <div class="two-columns">
    <div id="container-info">
      <h1>
        {titleMain}<br /><span class="colored-text">{titleHighlight}</span>
      </h1>
      <p>{description}</p>
      <ul role="list" class="list-none">
        <li>📅 Actualizado cada parche</li>
        <li>🎯 Probado en High Elo</li>
        <li>🗺️ Guías detalladas</li>
      </ul>
      <div class="two-columns space-between">
        <a class="btn-primary" href="#tier-list"
          >✔ DESCARGAR CHEATSHEET GRATIS</a
        >
        <a
          class="btn-secondary"
          href={`https://www.youtube.com/watch?v=${video.id}`}
          >✔ VER GUÍA DEL PARCHE 17.3</a
        >
      </div>
      <div class="two-columns space-between">
        <div class="info">
          <p>Última actualización: {lastUpdate}</p>
        </div>
        <div class="info">
          <p>
              Actualizado por <a
                href="https://www.twitch.tv/jupeson"
                target="_blank">Jupeson</a
              >, High Elo Player & Streamer
            </p>
        </div>
      </div>
      <img
        src="/tft/assets/master-p.webp"
        alt=""
        style={{ display: "flex", width: "100%" }}
      />
    </div>
    <div>
      <VideoComponent video={video} client:load />
    </div>
  </div>
  <!-- <img src="/tft/assets/master-p.webp" alt="" style={{display:"flex", width:"100%"}}/> -->
  <!-- <img src="/tft/assets/master-plan-tft-horizontal.webp" alt="" style={{display:"flex", width:"100%"}}/> -->
  <!-- <img src="/tft/assets/master-plan-tft-horizontal-3-1.webp" alt="" style={{display:"flex", width:"100%"}}/> -->

  <div class="three-columns">
    <div class="left-side">
      {
        tiersInfo.map((tier, index) => (
          <div key={index} class={`tier-info tier-card-${tier.tier}`}>
            <h3 class="tier-header">
              <span class={`tier-number tier-number-${tier.tier}`}>
                {tier.tier}
              </span>
              <span class={`tier-title tier-title-${tier.tier}`}>
                {tier.title}
              </span>
            </h3>
            <p class={`tier-text`}>{tier.text}</p>
          </div>
        ))
      }
    </div>

    <div class="middle-side">
      <!-- Aquí es donde se inyectará el componente de detalles si estamos en la vista de detalle -->
      <h2>Meta Comps</h2>
      {
        top10Comps.map((comp, index) => (
          <div key={index} class={`comp-card`}>
            <CardsCompos
              comp={comp}
              numeracion={index + 1}
              isActive={String(comp.id) === String(activeId)}
              client:load
            />
          </div>
        ))
      }
      <button id="ver-mas-button" data-expanded="false">Ver todas las composiciones</button>
      {
        restComps && restComps.map((comp, index) => {
          const isCurrentActive = String(comp.id) === String(activeId);
          return (
            <div 
              key={index} 
              class={`comp-card rest-comp-card ${isCurrentActive ? '' : 'hidden-comp'}`}
              data-active={isCurrentActive ? "true" : "false"}
            >
              <CardsCompos
                comp={comp}
                numeracion={index + 11}
                isActive={isCurrentActive}
                client:load
              />
            </div>
          );
        })
      }
    </div>

    <div class="right-side">
      <!-- <div id="resources">
        <div class="resources-header">
          <h2 id="resource-title">Recursos TFT</h2>
        </div>
        <div class="resources-body">
          <span id=""></span>
          <p id="resource-text"></p>
          <span id=""></span>
        </div>
      </div> -->
    </div>
  </div>
</LayoutMaxWidth>

<script>
  document.addEventListener("astro:page-load", () => {
    const verMasButton = document.getElementById("ver-mas-button");
    if (verMasButton) {
      verMasButton.addEventListener("click", () => {
        const restCards = document.querySelectorAll(".rest-comp-card");
        const isExpanded = verMasButton.getAttribute("data-expanded") === "true";
        
        if (!isExpanded) {
          // Mostrar todas las composiciones ocultas
          restCards.forEach(card => {
            card.classList.remove("hidden-comp");
          });
          verMasButton.textContent = "Ver menos composiciones";
          verMasButton.setAttribute("data-expanded", "true");
        } else {
          // Ocultar todas las que no estén marcadas como activas
          restCards.forEach(card => {
            const isActive = card.getAttribute("data-active") === "true";
            if (!isActive) {
              card.classList.add("hidden-comp");
            }
          });
          verMasButton.textContent = "Ver todas las composiciones";
          verMasButton.setAttribute("data-expanded", "false");
        }
      });
    }
  });
</script>

<style>
  #container-info {
    display: flex;
    position: relative;
    flex-direction: column;
    padding: 0 2rem;
    & h1 {
      text-align: left;
      text-decoration: none;
      margin-block-end: 0px;
      font-size: 3.5rem;
    }
    & p {
      text-align: left;
    }
    & ul {
      text-align: left;
    }
    & a {
      text-align: left;
      font-weight: 600;
    }
  }
  .colored-text {
    color: var(--bg-purple-secondary);
  }
  .two-columns {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .btn-primary {
    color: var(--color-white);
    background-color: var(--bg-purple-secondary);
    padding: 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    width: fit-content;
  }
  .btn-primary:hover {
    transform: scale(1.01);
    transition: all 0.5s ease;
    background-color: var(--bg-purple-hover-primary);
  }
  .btn-secondary {
    color: var(--color-white);
    border: 1px solid var(--bg-purple-primary);
    background-color: var(--bg-purple-secondary);
    padding: 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    width: fit-content;
  }
  .btn-secondary:hover {
    transform: scale(1.01);
    transition: all 0.5s ease;
    background-color: var(--bg-purple-hover-primary);
  }
  .space-between {
    justify-content: space-between;
  }
  .list-none {
    display: flex;
    gap: 1rem;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    list-style: "";
    margin-block-start: 0;
    padding-left: 0px;
    & li {
      content: "✔ ";
    }
  }

  .infoContainer{
    display:flex;
    flex-direction: row;
    gap: 1rem;
  }
  .info {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: flex-start;
    border: 2px solid var(--bg-purple-hover-primary);
    border-radius: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
  }

  .three-columns {
    display: grid;
    grid-template-columns: 1fr 4fr 1fr;
    gap: 2rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  @media only screen and (max-width: 900px) {
    .three-columns {
      grid-template-columns: none;
      display: flex;
      flex-direction: column;
    }
    .two-columns {
      grid-template-columns: none;
      display: flex;
      flex-direction: column;
    }
  }

  .left-side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    & .tier-info {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: flex-start;
      padding: 15px;
      box-sizing: border-box;
    }
    .tier-header {
      display: flex;
      flex-direction: column;
      flex-wrap: wrap;
      margin-block-start: 0;
      margin-block-end: 0;
    }
    .tier-card-S {
      background: linear-gradient(135deg, #8b000099, #3c0000cc);
      border-color: #ff32324d;
    }
    .tier-card-A {
      background: linear-gradient(135deg, #99730099, #503c00cc);
      border-color: #ffc8324d;
    }
    .tier-card-B {
      background: linear-gradient(135deg, #4b556399, #1f2937cc);
      border-color: #9ca3af4d;
    }
    .tier-card-C {
      background: linear-gradient(135deg, #6e3c1e99, #3c1e0acc);
      border-color: #b464324d;
    }
    .tier-number {
      font-size: 4rem;
    }
    .tier-title {
      font-size: 2rem;
      color: #ffc8324d;
    }
    .tier-text {
      font-size: 1rem;
      opacity: 0.8;
    }
  }
  #ver-mas-button {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: flex-start;
    padding: 15px;
    box-sizing: border-box;
    cursor: pointer;
    background-color: var(--bg-purple-secondary);
    border-color: var(--bg-purple-secondary);
    color: var(--color-white);
    border-radius: 0.5rem;
    width: 100%;
    font-size: 2rem;
    margin-bottom: 20px;
    text-align: center;
    justify-content: center;
  }
  #ver-mas-button:hover {
    transform: scale(1.01);
    transition: all 0.5s ease;
    background-color: var(--bg-purple-hover-primary);
  }
  .hidden {
    display: none;
  }
  .hidden-comp {
    display: none !important;
  }
</style>
