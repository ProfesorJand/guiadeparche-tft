---
import LayoutMaxWidth from "@layouts/LayoutMaxWidth.astro";
import CardsCompos from "@components/TFT/CardsCompos";
import { getConstantes, getMetadata } from "src/lib/cache/tftCache.js";
import {  setNumberPBE, urlDragon, dataTFTChampions, dataTFTAllItems} from "@stores/dataTFT";
import { crearJSONSchema } from "src/json/schema/crearJSONSchema";
import RegistrarseBTN from "./RegistrarseBTN.jsx";
import Youtube from "@components/youtube/Youtube.jsx";
import CampeonImgInTierList from "@components/TFT/meta/CampeonImgInTierList.jsx"

const constantes = await getConstantes();
const metadata = await getMetadata();

const lastUpdateComps = metadata.lastUpdatePBE;

interface Props {
  titleMain?: string;
  titleHighlight?: string;
  description?: string;
  lastUpdate?: string;
  video: { id: string; title: string; thumbnail: string };
  top10Comps: any[];
  restComps:any[];
  activeId?: string;
  snippetImgUrl: string;
}

const {
  titleMain = "TFT Comps: ",
  titleHighlight = `Mejores Composiciones Meta Set ${setNumberPBE} (Parche ${constantes.MetaCompVersionPBE})`,
  description = `Descubre las mejores TFT comps y composiciones TFT del Set ${setNumberPBE} actualizadas para el parche ${constantes.MetaCompVersionPBE}. Aquí encontrarás builds, objetos BIS, aumentos y estrategias para jugar las compos más fuertes del meta de Teamfight Tactics y subir elo más rápido.`,
  lastUpdate = lastUpdateComps || null,
  video,
  top10Comps,
  restComps = [],
  activeId = null,
  snippetImgUrl
} = Astro.props;
// console.log({top10Comps:top10Comps[0]})
// const allChampionsIfno = useStore(dataTFTChampions);
// const allItemsInfo = useStore(dataTFTAllItems);
// console.log({allChampionsIfno})
// console.log({allItemsInfo})

const tiersInfo = [
  {
    tier: "S",
    title: "Meta Definitivo",
    text: "Las composiciones más fuertes, estables y consistentes del meta actual. ",
  },
  {
    tier: "A",
    title: "Muy Fuertes",
    text: "Composiciones sólidas y confiables, excelentes opciones para subir de elo.",
  },
  {
    tier: "B",
    title: "Sólidas",
    text: "Opciones viables que pueden funcionar bien si las condiciones son favorables.",
  },
  {
    tier: "C",
    title: "Viables",
    text: "Composiciones situacionales o que requieren una ejecución más precisa. ",
  },
  {
    tier: "H",
    title: "Hero",
    text: "Composiciones que tienen aumento de heroe.",
  },
  {
    tier: "X",
    title: "Situacional",
    text: "Cuando cumplen ciertos requisitos.",
  },
];

const keywords =
  "TFT Meta, Meta comps, comps TFT, comp TFT, Meta TFT, composiciones TFT, build TFT, tft comps, compos tft";


const baseSchema = JSON.parse(
  crearJSONSchema({title: titleMain + " " + titleHighlight, description:description})
)
const JSONSchema = JSON.stringify(baseSchema);
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const urlRecursosTFT= [
  "https://youtu.be/hsU_1u38dOY",
  "https://youtu.be/EXZ6NdN9pVA",
  "https://youtu.be/PEuWSN1sD48",
  "https://youtu.be/12ejp2WlnZw",
  "https://youtu.be/sEG8PLrgO20",
  "https://youtu.be/qoV9hH9s9RI",
  "https://youtu.be/nD-1exiSgnE"
]
---

<LayoutMaxWidth 
  title={`${titleMain} ${titleHighlight}`}
  description={description}
  keywords={keywords}
  snippetImgUrl={snippetImgUrl}
  JSONSchema={JSONSchema}
  canonical={canonicalURL}
  >
  <div class="two-columns header-section">
    <div id="container-info">
      <h1>
        {titleMain}<br /><span class="colored-text">{titleHighlight}</span>
      </h1>
      <p>{description}</p>
      <div class="two-columns space-between">
        <div class="info">
          <p>
              Última actualización: {lastUpdate} 
              <!-- por
              <a
                href="https://www.twitch.tv/jupeson"
                target="_blank">Jupeson</a> y Xpirit -->
            </p>
        </div>
        <RegistrarseBTN
          text="¿Quieres probar el TFT Master Plan antes que nadie?"
          buttonText="Pre-regístrate gratis →"
          layout="row"
        />
      </div>
      
    </div>
    <div class="container-video">
      <Youtube src={constantes.videoPrincipal} client:load transition:persist />
      <!-- <img
        src="/tft/assets/master-p.webp"
        alt=""
        style={{ display: "flex", width: "100%" }}
      /> -->
    </div>
  </div>
 
  <div class="three-columns">
    <div class="left-side">
      <h2>Tier List</h2>
      {
        tiersInfo.map((tier, index) => (
          <div class={`tier-info tier-card-${tier.tier}`}>
            <h3 class="tier-header">
              
              <div class="container-tier-text">
              <span class={`tier-number tier-number-${tier.tier}`}>
                {tier.tier}
              </span>
              <span class={`tier-title tier-title-${tier.tier}`}>
                {tier.title}
              </span>
              </div>
              {
                [...top10Comps, ...restComps].length &&
                <div class="container-champs-tier">
                {[...top10Comps, ...restComps].filter((comp)=>{
                  if (tier.tier === 'H') {
                    return comp.tierExtra === 'H';
                  }
                  if (tier.tier === 'X') {
                    return comp.tierExtra === 'X';
                  }
                  return comp.tier === tier.tier;
                }).map((comp,index)=>{
                  const isActive = String(comp.compUrl) === String(activeId);
                  return (
                    // <div class="champ-tier" data-comp-id={comp.compUrl} data-is-active={isActive ? "true" : "false"} data-cost={comp?.campeonMeta?.cost}>
                    //   <img class="champ-tier-img" src={`${urlDragon()}${comp.campeonTierList.squareIcon.toLowerCase().replace(".tex",".png")}`} alt={comp.campeonTierList.name} />
                    //   <div class="champ-tier-items">
                    //     {
                    //       comp.champItem.map((item, index)=>{
                    //         return (
                    //           <img class="champ-tier-item-img" src={`${urlDragon()}${item?.icon.toLowerCase().replace(".tex",".png")}`} alt={item?.name} />
                    //         );
                    //       })
                    //     }
                    //   </div>
                    // </div>
                    <CampeonImgInTierList
                      apiNameCampeon={comp?.campeonMeta?.apiNameCampeon}
                      showItems={true}
                      apiNameItems={comp?.campeonMeta?.apiNameItemsDelCampeon}
                      compUrl={comp.compUrl}
                      client:load
                      transition:persist
                    />
                  );
                })}
                </div>
              }
            </h3>
            {/* <p class={`tier-text`}>{tier.text}</p> */}
          </div>
        ))
      }
    </div>

    <div class="middle-side">
      <!-- Aquí es donde se inyectará el componente de detalles si estamos en la vista de detalle -->
      <h2>Mejores TFT Comps del Meta Actual</h2>
      <p>Las compos están ordenadas por fuerza dentro del meta actual, desde las mejores opciones para subir elo hasta alternativas viables según tu spot.</p>
      {
        top10Comps.map((comp, index) => (
          <article class={`comp-card`}>
            <CardsCompos
              comp={comp}
              numeracion={index + 1}
              isActive={String(comp.compUrl) === String(activeId)}
              client:load
            />
          </article>
        ))
      }
      { restComps.length > 0 && <button id="ver-mas-button" data-expanded="false">Ver todas las composiciones</button>}
      {
        restComps && restComps.map((comp, index) => {
          const isCurrentActive = String(comp.compUrl) === String(activeId);
          return (
            <div 
              class={`comp-card rest-comp-card ${isCurrentActive ? '' : 'hidden-comp'}`}
              data-active={isCurrentActive ? "true" : "false"}
            >
              <CardsCompos
                comp={comp}
                numeracion={index + 11}
                isActive={isCurrentActive}
                client:load
              />
            </div>
          );
        })
      }
    </div>

    <div class="right-side">
      <div id="resources">
        <div class="resources-header">
          <h2 id="resource-title">Recursos TFT</h2>
        </div>
        <div class="resources-body">
          {
            urlRecursosTFT.map((url, index)=>{
              return <Youtube src={url} client:load transition:persist={`youtube-recurso-${index}`} />
            })
          }

        </div>
      </div>
    </div>
  </div>
</LayoutMaxWidth>

<script>
  document.addEventListener("astro:page-load", () => {
    const verMasButton = document.getElementById("ver-mas-button");
    const restCards = document.querySelectorAll(".rest-comp-card");

    const expandComps = () => {
      restCards.forEach(card => {
        card.classList.remove("hidden-comp");
      });
      if (verMasButton) {
        verMasButton.textContent = "Ver menos composiciones";
        verMasButton.setAttribute("data-expanded", "true");
      }
    };

    const collapseComps = () => {
      restCards.forEach(card => {
        const isActive = card.getAttribute("data-active") === "true";
        if (!isActive) {
          card.classList.add("hidden-comp");
        }
      });
      if (verMasButton) {
        verMasButton.textContent = "Ver todas las composiciones";
        verMasButton.setAttribute("data-expanded", "false");
      }
    };

    // Restaurar estado al cargar la página
    const savedExpanded = localStorage.getItem("tft-comps-expanded") === "true";
    if (savedExpanded) {
      expandComps();
    } else {
      collapseComps();
    }

    if (verMasButton) {
      verMasButton.addEventListener("click", () => {
        const isExpanded = verMasButton.getAttribute("data-expanded") === "true";
        if (!isExpanded) {
          expandComps();
          localStorage.setItem("tft-comps-expanded", "true");
        } else {
          collapseComps();
          localStorage.setItem("tft-comps-expanded", "false");
        }
      });
    }

    // Manejar click en los campeones de la lista de tiers
    const champTiers = document.querySelectorAll(".champ-tier");
    champTiers.forEach(element => {
      element.addEventListener("click", (e) => {
        e.preventDefault();
        
        const compUrlId = element.getAttribute("data-comp-id");
        const isActive = element.getAttribute("data-is-active") === "true";
        
        // Solo guardar posición de scroll si se va a abrir (para no sobreescribir al cerrar)
        if (!isActive) {
          sessionStorage.setItem("tft-scroll-position", window.scrollY.toString());
        }
        
        const targetUrl = isActive
          ? "/tft/meta-comps-tier-list-teamfight-tactics"
          : `/tft/meta-comps-tier-list-teamfight-tactics/${compUrlId}`;
          
        import("astro:transitions/client").then(({ navigate }) => {
          navigate(targetUrl, { scroll: false });
        });
      });
    });

    // Restaurar posición de scroll al volver a la página principal
    const segments = window.location.pathname.split("/").filter(Boolean);
    const isMainPage = segments.length <= 2; // e.g. /tft/nueva-pagina
    
    if (isMainPage) {
      const savedPosition = sessionStorage.getItem("tft-scroll-position");
      if (savedPosition) {
        setTimeout(() => {
          const html = document.documentElement;
          const originalScrollBehavior = html.style.scrollBehavior;
          html.style.scrollBehavior = "auto";
          window.scrollTo(0, parseInt(savedPosition));
          html.style.scrollBehavior = originalScrollBehavior;
        }, 50);
      }
    }
  });
</script>

<style>
  .header-section{
    width:calc(100% * 4 / 6);
    align-self: center;
    margin-bottom: 12px;
  }
  #container-info {
    display: flex;
    position: relative;
    flex-direction: column;
    width: 60%;
    justify-content: space-between;
    & h1 {
      text-align: left;
      text-decoration: none;
      margin-block-end: 0px;
      margin-block-start: 0px;
      font-size: 2rem;
    }
    & p {
      text-align: left;
    }
    & ul {
      text-align: left;
    }
    & a {
      text-align: left;
      font-weight: 600;
    }
  }
  .container-video{
    display:flex;
    width:40%;
    flex-direction:column;
    gap:12px;
    justify-content: center;
    align-items: center;
  }
  .two-columns {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    justify-content: center;
    
  }
  .btn-primary {
    color: var(--color-white);
    background-color: var(--bg-purple-secondary);
    padding: 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    width: fit-content;
  }
  .btn-primary:hover {
    transform: scale(1.01);
    transition: all 0.5s ease;
    background-color: var(--bg-purple-hover-primary);
  }
  .btn-secondary {
    color: var(--color-white);
    border: 1px solid var(--bg-purple-primary);
    background-color: var(--bg-purple-secondary);
    padding: 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    width: fit-content;
  }
  .btn-secondary:hover {
    transform: scale(1.01);
    transition: all 0.5s ease;
    background-color: var(--bg-purple-hover-primary);
  }
  .space-between {
    justify-content: space-between;
  }
  .list-none {
    display: flex;
    gap: 1rem;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    list-style: "";
    margin-block-start: 0;
    padding-left: 0px;
    & li {
      content: "✔ ";
    }
  }

  .infoContainer{
    display:flex;
    flex-direction: row;
    gap: 1rem;
  }
  .info {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: flex-start;
    border: 2px solid var(--bg-purple-hover-primary);
    border-radius: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    box-sizing: border-box;
  }


  .three-columns {
    display: grid;
    grid-template-columns: 1fr 4fr 1fr;
    gap: 2rem;
    justify-content: center;
    margin-bottom: 1rem;
    border-top: 0.5px solid rgba(128, 128, 128, 0.185);
  }

  .resources-body{
    display:flex;
    flex-direction:column;
    gap:20px;
  }
  .container-tier-text{
    display:flex;
    flex-direction: row;
    gap:10px;
    align-items: center;
  }
  .container-champs-tier{
    display:grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap:10px;
    flex-wrap: wrap;
  }
  .champ-tier{
    display:flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    width:calc(100% / 3 - (10px * 2 / 3));
    transform: scale(0.95)
  }
  .champ-tier:hover {
    transform: scale(1);
  }
  .champ-tier:active {
    transform: scale(1);
  }
  .champ-tier[data-is-active="true"] {
    transform: scale(1);
  }
  .champ-tier-img{
    width:100%;
    border: 2px solid var(--bg-purple-hover-primary);
    border-radius: 0.5rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  
  /* Bordes y Glows personalizados basados en el coste del campeón */
  .champ-tier[data-cost="1"] .champ-tier-img { border-color: var(--color-hex-cost-1, grey); }
  .champ-tier[data-cost="2"] .champ-tier-img { border-color: var(--color-hex-cost-2, green); }
  .champ-tier[data-cost="3"] .champ-tier-img { border-color: var(--color-hex-cost-3, aqua); }
  .champ-tier[data-cost="4"] .champ-tier-img { border-color: var(--color-hex-cost-4, purple); }
  .champ-tier[data-cost="5"] .champ-tier-img { border-color: var(--color-hex-cost-5, gold); }

  /* Glows al pasar el mouse por encima */
  .champ-tier[data-cost="1"]:hover .champ-tier-img { box-shadow: 0 0 12px rgba(128, 128, 128, 0.6); }
  .champ-tier[data-cost="2"]:hover .champ-tier-img { box-shadow: 0 0 12px rgba(34, 197, 94, 0.6); }
  .champ-tier[data-cost="3"]:hover .champ-tier-img { box-shadow: 0 0 12px rgba(0, 255, 255, 0.6); }
  .champ-tier[data-cost="4"]:hover .champ-tier-img { box-shadow: 0 0 12px rgba(168, 85, 247, 0.6); }
  .champ-tier[data-cost="5"]:hover .champ-tier-img { box-shadow: 0 0 12px rgba(234, 179, 8, 0.6); }

  /* Glows permanentes cuando la composición está seleccionada/activa */
  .champ-tier[data-is-active="true"][data-cost="1"] .champ-tier-img { box-shadow: 0 0 18px rgba(128, 128, 128, 0.9), 0 0 5px rgba(128, 128, 128, 0.5); }
  .champ-tier[data-is-active="true"][data-cost="2"] .champ-tier-img { box-shadow: 0 0 18px rgba(34, 197, 94, 0.9), 0 0 5px rgba(34, 197, 94, 0.5); }
  .champ-tier[data-is-active="true"][data-cost="3"] .champ-tier-img { box-shadow: 0 0 18px rgba(0, 255, 255, 0.9), 0 0 5px rgba(0, 255, 255, 0.5); }
  .champ-tier[data-is-active="true"][data-cost="4"] .champ-tier-img { box-shadow: 0 0 18px rgba(168, 85, 247, 0.9), 0 0 5px rgba(168, 85, 247, 0.5); }
  .champ-tier[data-is-active="true"][data-cost="5"] .champ-tier-img { box-shadow: 0 0 18px rgba(234, 179, 8, 0.9), 0 0 5px rgba(234, 179, 8, 0.5); }
  .champ-tier-items{
    display:flex;
    flex-direction: row;
    /* gap:10px; */
    /* flex-wrap: wrap; */
  }
  .champ-tier-item-img{
    width:calc(100% / 3);
    border-radius: 0.5rem;
  }



  .left-side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    & .tier-info {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: flex-start;
      padding: 15px;
      box-sizing: border-box;
      border-radius: 0.5rem;
      
    }
    .tier-header {
      display: flex;
      flex-direction: column;
      flex-wrap: wrap;
      margin-block-start: 0;
      margin-block-end: 0;
    }
    .tier-card-S {
      background: linear-gradient(135deg, #8b000099, #3c0000cc);
      border-color: #ff32324d;
    }
    .tier-card-A {
      background: linear-gradient(135deg, #99730099, #503c00cc);
      border-color: #ffc8324d;
    }
    .tier-card-B {
      background: linear-gradient(135deg, #4b556399, #1f2937cc);
      border-color: #9ca3af4d;
    }
    .tier-card-C {
      background: linear-gradient(135deg, #6e3c1e99, #3c1e0acc);
      border-color: #b464324d;
    }
    .tier-card-H {
      background: linear-gradient(135deg, #10b98199, #064e3bcc);
      border-color: #34d3994d;
    }
    .tier-card-X {
      background: linear-gradient(135deg, #06b6d499, #164e63cc);
      border-color: #22d3ee4d;
    }
    .tier-number {
      font-size: 4rem;
    }
    .tier-title {
      font-size: 2rem;
      color: #ffc8324d;
    }
    .tier-text {
      font-size: 1rem;
      opacity: 0.8;
    }
  }
  #ver-mas-button {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: flex-start;
    padding: 15px;
    box-sizing: border-box;
    cursor: pointer;
    background-color: var(--bg-purple-secondary);
    border-color: var(--bg-purple-secondary);
    color: var(--color-white);
    border-radius: 0.5rem;
    width: 100%;
    font-size: 2rem;
    margin-bottom: 20px;
    text-align: center;
    justify-content: center;
  }
  #ver-mas-button:hover {
    transform: scale(1.01);
    transition: all 0.5s ease;
    background-color: var(--bg-purple-hover-primary);
  }
  .hidden {
    display: none;
  }
  .hidden-comp {
    display: none !important;
  }
  @media only screen and (max-width: 900px) {
    #container-info{
      width:100%;
      & h1{
        font-size:1.5rem;
      }
    }
    .header-section{
      width:100%;
    }

    .container-video{
      width:100%
    }

    .left-side{
      order: 2
    }

    .three-columns {
      grid-template-columns: none;
      display: flex;
      flex-direction: column;
    }
    .two-columns {
      grid-template-columns: none;
      display: flex;
      flex-direction: column;
    }
  }
</style>
