---
import styles from "./css/PaginaBaseMaxWidth.module.css";
const {
  topTitle,
  lowerTitle,
  textInfo,
  videoHeadersLength,
  
} = Astro.props;

const hasLeft = Astro.slots.has("bodyContainerLeft");
const hasMid = Astro.slots.has("bodyContainerMid");
const hasRight = Astro.slots.has("bodyContainerRight");
const hasSideVideo = Astro.slots.has("videoSideHeader");

let layoutClass = "";
if (hasLeft && hasMid && hasRight) {
  layoutClass = styles.layoutThreeCols;
} else if (hasLeft && hasMid) {
  layoutClass = styles.layoutLeftMid;
} else if (hasMid && hasRight) {
  layoutClass = styles.layoutMidRight;
} else if (hasMid) {
  layoutClass = styles.layoutOnlyMid;
}

const paragraphs = Array.isArray(textInfo)
  ? textInfo
  : (typeof textInfo === 'string' ? textInfo.split(/\r?\n/) : []);
---

    <div class={styles.pageContainer}>
      <div class={styles.headerSection}>
        <div class={`${styles.headerInfo} ${!hasSideVideo ? styles.headerInfoFull : ""}`}>
          <h1>
            {topTitle}<br/>
            <span class={styles.lowerTitle}>{lowerTitle}</span>
          </h1>
          {paragraphs.map((paragraph) => {
            const trimmed = typeof paragraph === 'string' ? paragraph.trim() : paragraph;
            return trimmed ? <p>{trimmed}</p> : null;
          })}
          <slot name="moreInfoHeader"/>
        </div>
      </div>
      <div class={`${styles.bodyContainer} ${layoutClass}`}>
        {hasLeft && 
          <div class={styles.colLeft}>
            <slot name="bodyContainerLeft"/>
          </div>
        }
        {hasMid && 
          <div class={styles.colMid}>
            <slot name="bodyContainerMid" />
          </div>
        }
        {hasRight && 
          <div class={styles.colRight}>
            <slot name="bodyContainerRight"/>
          </div>
        }
      </div>
      <slot name="footer"/>
    </div>

<style is:global>
  .bodyContainerMid{
    display:flex;
    flex-direction: column;
    gap:20px;
  }
  .indiceColumna{
    display:flex;
    flex-direction: row;
    width: 100%;
    justify-content: center;
    align-items: flex-start;
    gap:20px;
    & ol{
      width:100%;
    }
    padding:20px;
    box-sizing: border-box;
    border-bottom: 2px solid grey;
  }
  ol{
    list-style-type: none;
    padding-left: 0;
    margin: 0;
    font-size:1.2rem;
    line-height: 1.5;
  }
  li a {
    text-decoration: none;
    &:hover{
      text-decoration: underline;
      color: var(--color-white)
    }
  }
  ul{
    margin-block-start:0;
  }
  ol ol {
    padding-left: 20px;
    margin-top: 10px; /* Espacio entre el título principal y los sub-ítems */
  }
  ol li:not(:has(ol)) {
    margin-bottom: 12px; /* Espacio (gap) entre los sub-ítems / ítems hojas */
    margin-top: 0;
  }
  ol li:not(:has(ol)):last-child {
    margin-bottom: 0;
  }
   h2{
      font-size: 2rem;
      text-align: left;
    }
     h3{
      font-size: 1.6rem;
    }
     p{
      font-size:1.2rem;
      line-height: 1.5;
      margin-block-end: 0;
      margin-block-start: 0;
    }
     li{
      font-size: 1.2rem;
      line-height: 1.5;
      margin-bottom: 12px;
    }

  details {
    background: rgba(16, 21, 37, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    margin-bottom: 1.25rem;
    padding: 1rem 1.25rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  details:hover {
    border-color: var(--bg-purple-secondary);
    background: rgba(29, 21, 170, 0.15);
    box-shadow: 0 4px 25px rgba(107, 34, 115, 0.15);
  }

  details[open] {
    border-color: rgba(107, 34, 115, 0.6);
    background: rgba(16, 21, 37, 0.85);
  }

  details summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--text-color-white-primary);
    cursor: pointer;
    user-select: none;
    list-style: none;
  }

  details summary::-webkit-details-marker {
    display: none;
  }

  details summary::after {
    content: "";
    display: inline-block;
    width: 8px;
    height: 8px;
    border-right: 2px solid var(--text-color-white-primary);
    border-bottom: 2px solid var(--text-color-white-primary);
    transform: rotate(45deg);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin-right: 0.5rem;
  }

  details[open] > summary::after {
    transform: rotate(-135deg);
    border-color: var(--bg-purple-secondary);
  }

  details[open] > summary {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.75rem;
    margin-bottom: 0.75rem;
  }

  details > *:not(summary) {
    animation: slideFadeIn 0.35s ease-out;
  }

  @keyframes slideFadeIn {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  details ol {
    margin-top: 0.5rem;
    margin-bottom: 0;
  }
  
  @media (max-width: 900px) {
   .indiceColumna{
    flex-direction:column;
  }
 }
</style>
  


