    </div>

    <div slot="bodyContainerRight">
      <!-- Columna derecha vacía para consistencia -->
    </div>
  </PaginaBaseMaxWidth>
</LayoutMaxWidth>

<style>
  .bodyContainerMid {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin: 0 auto;
  }

  /* Cards Grid */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin: 20px 0;
  }

  @media (max-width: 768px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }

  .nav-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    align-items: flex-start;
    gap: 15px;
    text-decoration: none;
    color: #ffffff;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .nav-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 215, 0, 0.3);
    box-shadow: 0 8px 25px rgba(255, 215, 0, 0.15);
  }

  .nav-card-icon {
    font-size: 2rem;
    background: rgba(255, 215, 0, 0.1);
    border-radius: 12px;
    min-width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffd700;
  }

  .nav-card-info h3 {
    margin: 0 0 5px 0;
    font-size: 1.2rem;
    /* font-family: 'ObvioslyWideBold', sans-serif; */
    color: #ffffff;
    transition: color 0.3s ease;
  }

  .nav-card:hover h3 {
    color: #ffd700;
  }

  .nav-card-info p {
    margin: 0;
    font-size: 0.9rem;
    color: #94a3b8;
    line-height: 1.4;
  }

  /* Video Embeds */
  .video-embed-container {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    margin: 20px 0;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  /* Image Showcase */
  .image-showcase {
    width: 100%;
    display: flex;
    justify-content: center;
    margin: 20px 0;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .responsive-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* Consejo Items */
  .consejos-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin: 25px 0;
  }

  .consejo-item {
    border-radius: 12px;
    padding: 20px;
    border-left: 4px solid;
  }

  .consejo-item h4 {
    margin: 0 0 10px 0;
    font-family: 'ObvioslyWideBold', sans-serif;
    font-size: 1.1rem;
  }

  .consejo-item p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.5;
    color: #cbd5e1;
  }

  .consejo-item.avoid {
    border-left-color: #ef4444;
    background: rgba(239, 68, 68, 0.04);
  }

  .consejo-item.avoid h4 {
    color: #f87171;
  }

  .consejo-item.practice {
    border-left-color: #10b981;
    background: rgba(16, 185, 129, 0.04);
  }

  .consejo-item.practice h4 {
    color: #34d399;
  }

  .consejo-item.mistakes {
    border-left-color: #f59e0b;
    background: rgba(245, 158, 11, 0.04);
  }

  .consejo-item.mistakes h4 {
    color: #fbbf24;
  }

  /* Composiciones Highlight */
  .comp-highlight {
    background: linear-gradient(135deg, rgba(136, 58, 234, 0.12) 0%, rgba(20, 16, 75, 0.4) 100%);
    border: 1px solid rgba(136, 58, 234, 0.3);
    border-radius: 18px;
    padding: 25px;
    margin: 30px 0;
    box-shadow: 0 8px 30px rgba(136, 58, 234, 0.1);
  }

  .comp-card-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 15px;
  }

  .comp-card-content p {
    margin: 0;
  }

  .bold-text {
    font-size: 1.25rem;
    font-weight: bold;
    color: #ffd700;
  }

  .cta-action-container {
    margin-top: 10px;
  }

  .btn-meta-redirect {
    display: inline-block;
    padding: 12px 35px;
    background: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%);
    color: #0c023a;
    text-decoration: none;
    font-weight: bold;
    font-family: 'ObvioslyWideBold', sans-serif;
    border-radius: 50px;
    text-transform: uppercase;
    font-size: 0.95rem;
    letter-spacing: 0.5px;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow: 0 4px 15px rgba(255, 140, 0, 0.3);
  }

  .btn-meta-redirect:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 6px 20px rgba(255, 140, 0, 0.5);
    color: #0c023a;
  }

  /* Table */
  .table-container {
    width: 100%;
    overflow-x: auto;
    margin: 20px 0;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }

  .dates-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    background: rgba(255, 255, 255, 0.02);
  }

  .dates-table th, .dates-table td {
    padding: 15px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .dates-table th {
    background: rgba(255, 255, 255, 0.05);
    color: #ffd700;
    font-family: 'ObvioslyWideBold', sans-serif;
    font-size: 0.95rem;
    letter-spacing: 0.5px;
  }

  .dates-table tbody tr:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 25px;
  }

  .faq-item {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 20px;
    transition: background 0.3s ease;
  }

  .faq-item:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .faq-item h4 {
    margin: 0 0 10px 0;
    font-size: 1.15rem;
    color: #ffd700;
    font-family: 'ObvioslyWideBold', sans-serif;
  }

  .faq-item p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.5;
    color: #cbd5e1;
  }

  .faq-item a {
    color: #00f2fe;
    text-decoration: none;
    font-weight: 500;
  }

  .faq-item a:hover {
    text-decoration: underline;
  }

  .mb-20 {
    margin-bottom: 20px;
  }
</style>
