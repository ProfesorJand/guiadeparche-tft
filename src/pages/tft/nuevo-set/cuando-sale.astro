---
import LayoutMaxWidth from "@layouts/LayoutMaxWidth.astro";
import { crearJSONSchema } from "@json/schema/crearJSONSchema";
import PaginaBaseMaxWidth from "@components/TFT/paginas/PaginaBaseMaxWidth.astro";
import Youtube from "@components/youtube/Youtube.jsx";
import VideoComponent from "@components/youtube/VideoComponent";
import DynamicSection from "@layouts/sections/DynamicSection.astro";
import TableOfContent from "@layouts/sidebar/TableOfContent.astro";

const topTitle = "¿Cuándo Sale el Set 18 de TFT?";
const lowerTitle = "Fecha Oficial de Lanzamiento";
const title = `${lowerTitle ? topTitle +" "+ lowerTitle : topTitle}`;

const description = [
  "Riot Games ya ha confirmado la fecha de lanzamiento del Set 18 de Teamfight Tactics, conocido como Bosque Misterioso. En esta guía encontrarás cuándo estará disponible en el servidor de pruebas PBE, cuándo llegará a los servidores oficiales y todas las novedades que se conocen hasta el momento sobre el próximo Set de TFT.",
  "Si estás esperando el lanzamiento para probar las nuevas mecánicas, campeones y composiciones, aquí iremos actualizando toda la información oficial conforme Riot revele más detalles."
];

const keywords = "Cuando es el nuevo Set de TFT, Set 18 TFT, fecha set 18 tft, fecha del nuevo set tft, fecha lanzamiento set 18 tft";

const canonical = new URL(Astro.url.pathname, Astro.site).href;

const baseSchema = JSON.parse(
  crearJSONSchema({title, description: description})
);
const JSONSchema = JSON.stringify(baseSchema);

const currentPath = Astro.url.pathname;
const SIDEBAR =[
  {
    label:"Fecha de lanzamiento del Set 18 de TFT",
    href:"#fecha-lanzamiento-set-18"
  },
  {
    label:"Cuándo sale el nuevo Set de TFT",
    href:"#cuando-sale-nuevo-set"
  },
  {
    label:"Qué sabemos del Set 18 Bosque Misterioso",
    href:"#set-18-bosque-misterioso"
  },
  {
    label:"Recursos del Set 18",
    href:"#recursos-set-18"
  },
  {
    label:"¿Quieres dominar el Set 17?",
    href:"#dominar-tft-set-17"
  }
]
---

<LayoutMaxWidth
  title={title}
  description={description}
  keywords={keywords}
  JSONSchema={JSONSchema}
  canonical={canonical}
>
  <PaginaBaseMaxWidth
    topTitle={topTitle}
    lowerTitle={lowerTitle}
    textInfo={description}
  >
      <DynamicSection>
        <div slot="main">
          <img style={{width:"50%", alignSelf:"center"}} src="/tft/sets/18/TFT-Set-18-lanzamiento-cuando-sale-confirmado.webp" alt="TFT Set 18 lanzamiento cuando sale confirmado" />
          <!-- <Youtube src="https://www.youtube.com/watch?v=YlivZPdB69I" client:load /> -->
            <h2 id="fecha-lanzamiento-set-18">Fecha de Lanzamiento del Set 18 de TFT</h2>
            <p>
              El Set 18 de Teamfight Tactics llegará oficialmente el 12 de agosto de 2026 junto con el parche 18.1 en todos los servidores del mundo.
            </p>
            <p>
              Como ocurre con cada lanzamiento importante de TFT, los jugadores podrán probar el contenido antes de su llegada oficial a través del entorno público de pruebas (PBE). 
            </p>
    
            <h2 id="cuando-sale-nuevo-set">¿Cuándo Sale el Set 18 en el PBE?</h2>
            <p>Antes de llegar a los servidores oficiales, el Set 18 estará disponible en el PBE durante aproximadamente dos semanas.</p>
            <p>
              La llegada al PBE está prevista, programado para el 14 de Julio de 2026, permitiendo a los jugadores probar las nuevas mecánicas y campeones durante 4 semana antes del lanzamiento global.
            </p>        
              <Youtube src="https://www.youtube.com/watch?v=WnB0H48FE6Q" client:load />
    
            <h2 id="set-18-bosque-misterioso">¿Qué Sabemos del Set 18 Bosque Misterioso?</h2>
            <p>
              Riot ha confirmado que la temática principal del Set 18 será de Bosque Misterioso. Aunque todavía no se han revelado todos los detalles, se espera una nueva mecánica central, campeones inéditos dentro del ecosistema de TFT y un conjunto completamente renovado de sinergias y estrategias.
            </p>
            <p>
              Además Teamfight Tactics hará en este Set su migración a cliente propio (separado de League of Legends) y cambiará su motor tecnológico a Unreal Engine, detalles del cambio en el siguiente video:
            </p>
    
            <h2 id="recursos-set-18">Recursos del Set 18</h2>
            <div class="cards-grid">
            <a href="/tft/nuevo-set" class="nav-card">
              <div class="nav-card-icon">✨</div>
              <div class="nav-card-info">
                <h3>Nuevo Set TFT</h3>
                <p>Todo sobre el nuevo set de TFT.</p>
              </div>
            </a>
            <a href="/tft/nuevo-set/consejos-tips-para-mejorar" class="nav-card">
              <div class="nav-card-icon">💡</div>
              <div class="nav-card-info">
                <h3>Consejos del Set</h3>
                <p>Aprende de estos tips de Jupeson para subir de elo fácilmente en Teamfight Tactics.</p>
              </div>
            </a>
            <a href="/tft/meta-comps-tier-list-teamfight-tactics" class="nav-card">
              <div class="nav-card-icon">🏆</div>
              <div class="nav-card-info">
                <h3>Mejores Composiciones TFT</h3>
                <p>Consulta el tier list y las mejores configuraciones para subir de rango.</p>
              </div>
            </a>
            <a href="/tft/como-jugar" class="nav-card">
              <div class="nav-card-icon">📚</div>
              <div class="nav-card-info">
                <h3>Cómo Jugar TFT</h3>
                <p>Aprende cómo jugar TFT con esta guía completa de Teamfight Tactics para principiantes y jugadores que quieren mejorar.</p>
              </div>
            </a>
          </div>
            
          <h2 id="dominar-tft-set-17">¿Quieres dominar el Set 17?</h2>
          <p>
            Estos son solo algunos de los consejos más importantes del Set actual. Si buscas las composiciones más fuertes del meta,
            los mejores objetos, aumentos recomendados y guías completas actualizadas tras cada parche, consulta nuestra Tier List
            de TFT y las guías detalladas de cada composición.
          </p>
          <a href="/tft/meta-comps-tier-list-teamfight-tactics/" class="cta-button" >
            Ver Mejores Composiciones del Set 17
          </a>
        </div>
        <div slot="sidebar">
          <TableOfContent items={SIDEBAR} />
        </div>
      </DynamicSection>

  </PaginaBaseMaxWidth>
</LayoutMaxWidth>

<style>
  .cta-button {
    display: flex;
    background-color: var(--bg-purple-primary);
    padding: 12px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    margin-top: 1rem;
    border: 2px solid var(--color-primary);
    text-align: center;
    width: fit-content;
    &:hover {
      background-color: var(--bg-purple-secondary);
      border-color: var(--color-secondary);
      color: var(--color-white);
    }
  }
  article{
    & p{
      margin-bottom:10px;
    }
  }
    /* Cards Grid */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin: 20px 0;
  }

  .nav-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    align-items: flex-start;
    gap: 15px;
    text-decoration: none;
    color: #ffffff;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .nav-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 215, 0, 0.3);
    box-shadow: 0 8px 25px rgba(255, 215, 0, 0.15);
  }

  .nav-card-icon {
    font-size: 2rem;
    background: rgba(255, 215, 0, 0.1);
    border-radius: 12px;
    min-width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffd700;
  }

  .nav-card-info h3 {
    margin: 0 0 5px 0;
    font-size: 1.2rem;
    /* font-family: 'ObvioslyWideBold', sans-serif; */
    color: #ffffff;
    transition: color 0.3s ease;
  }

  .nav-card:hover h3 {
    color: #ffd700;
  }

  .nav-card-info p {
    margin: 0;
    font-size: 0.9rem;
    color: #94a3b8;
    line-height: 1.4;
  }


  @media (max-width: 900px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>