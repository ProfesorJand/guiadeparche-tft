const { initialId } = Astro.props;

const title = "Cómo Jugar TFT: Guía Definitiva para Principiantes (2026)";
const description = "Aprende cómo jugar Teamfight Tactics desde cero. Descubre las mecánicas del Set 17, objetos, economía y la guía de los Dioses para subir de rango.";

