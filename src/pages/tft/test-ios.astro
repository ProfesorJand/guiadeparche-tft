---
import Layout from "@layouts/Layout.astro";
import TestIOSReact from '../../components/TFT/TestIOSReact.jsx';
import TierListMetaComps from "@components/TFT/TierListMetaComps.jsx";
import Main from "@components/main/Main.astro";
import Composicion from "@components/main/Admin/Composicion.jsx";
import { TestIOSReactOpcion2, TestIOSReactOpcion3 } from "@components/TFT/TestIOSReactOpciones.jsx";

const todasLasCompsPBE = await fetchAndSortComps(composMetaPBEJSON);
---

<Layout title="Test iOS Click" description="Página de prueba para problemas de clics en iOS">
   <Fragment slot="bodyMainAside">
    <TierListMetaComps
      todasLasCompsPBE={todasLasCompsPBE}
      client:only="react"
    />
    </Fragment>
    <Main>

    
  <div class="test-container" style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem; color: white;">
    <h1 style="font-size: 2rem; margin-bottom: 1rem; color: #f1fa8c;">Prueba de Clics en iOS</h1>
    <p style="margin-bottom: 2rem; color: #ccc;">
      Por favor, prueba estos diferentes métodos para abrir/cerrar contenido en tu iPhone (en Safari y Chrome). 
      Haz clic en cada uno y verifica si se abre el texto debajo. Esto nos dirá exactamente por qué falla la página de composiciones.
    </p>

    <!-- Test 1: Div normal sin cursor pointer (Falla mucho en iOS) -->
    <div class="test-box" style="margin-bottom: 1.5rem;">
      <div class="toggle-header" id="test1-header" style="background: #333; padding: 1rem; border-radius: 8px; border: 1px solid #444;">
        🔴 Prueba 1: Div nativo (sin cursor: pointer)
      </div>
      <div class="toggle-content" id="test1-content" style="display: none; padding: 1rem; background: #222; margin-top: 5px; border-left: 4px solid #f1fa8c;">
        ✅ ¡Funciona! El clic fue detectado.
      </div>
    </div>

    <!-- Test 2: Div con cursor: pointer (A veces soluciona el problema de iOS) -->
    <div class="test-box" style="margin-bottom: 1.5rem;">
      <div class="toggle-header" id="test2-header" style="background: #333; padding: 1rem; border-radius: 8px; cursor: pointer; border: 1px solid #444;">
        🟢 Prueba 2: Div nativo (CON cursor: pointer)
      </div>
      <div class="toggle-content" id="test2-content" style="display: none; padding: 1rem; background: #222; margin-top: 5px; border-left: 4px solid #50fa7b;">
        ✅ ¡Funciona! Al tener cursor:pointer, iOS lo considera clickeable.
      </div>
    </div>

    <!-- Test 3: Botón nativo (El más seguro para iOS) -->
    <div class="test-box" style="margin-bottom: 1.5rem;">
      <button class="toggle-header" id="test3-header" style="background: #333; padding: 1rem; border-radius: 8px; width: 100%; text-align: left; border: 1px solid #444; color: white; cursor: pointer; font-size: 1rem; font-family: inherit;">
        🔵 Prueba 3: Elemento Button (HTML)
      </button>
      <div class="toggle-content" id="test3-content" style="display: none; padding: 1rem; background: #222; margin-top: 5px; border-left: 4px solid #8be9fd;">
        ✅ ¡Funciona! Este es el método más estándar.
      </div>
    </div>

    <!-- Test 4: Details y Summary (Nativo del navegador, no usa JS) -->
    <div class="test-box" style="margin-bottom: 2rem;">
      <details style="background: #333; padding: 1rem; border-radius: 8px; cursor: pointer; border: 1px solid #444;">
        <summary style="outline: none; font-weight: bold;">🟠 Prueba 4: Details (Nativo, sin JS)</summary>
        <div style="padding: 1rem; background: #222; margin-top: 10px; border-left: 4px solid #ffb86c;">
          ✅ ¡Funciona! Al abrirse no usa JavaScript en absoluto.
        </div>
      </details>
    </div>

    <!-- Pruebas de React -->
    <TestIOSReact client:load />

    <!-- Prueba 7: OPCIÓN 1 (Astro con AddEventListener Seguro) -->
    <div class="test-box" style="margin-top: 3rem; margin-bottom: 2rem; border-top: 2px dashed #444; padding-top: 2rem;">
      <h2 style="color: #ffb86c; margin-bottom: 1rem;">Opción 1: AddEventListener Limpio (Astro)</h2>
      <p style="color: #ccc; margin-bottom: 1rem;">Usa el código original pero clona los botones para borrar cualquier evento "fantasma" que cause doble clic.</p>
      {
        todasLasCompsPBE.slice(0, 3).map((comp, index) => (
          <div style="margin-bottom: 1rem;">
            <button 
              class="op1-btn"
              data-comp-id={comp.id}
              style="background: #333; padding: 1rem; border-radius: 8px; width: 100%; text-align: left; border: 1px solid #444; color: white; cursor: pointer; margin-bottom: 0.5rem;"
            >
              🔴 Abrir Opción 1 (ID: {comp.id})
            </button>
            <div class="op1-container hide" data-comp-id={comp.id}>
              <Composicion id={comp.id} compo={comp} client:load />
            </div>
          </div>
        ))
      }
    </div>

    <!-- Prueba 8: OPCIÓN 2 (Astro + React Render Condicional) -->
    <div class="test-box" style="margin-bottom: 2rem; border-top: 2px dashed #444; padding-top: 2rem;">
      <h2 style="color: #8be9fd; margin-bottom: 1rem;">Opción 2: Sin CSS "display: none"</h2>
      <p style="color: #ccc; margin-bottom: 1rem;">Usa React para <b>crear/destruir</b> el componente en lugar de solo ocultarlo con CSS, evitando bugs de hidratación de Safari.</p>
      {
        todasLasCompsPBE.slice(3, 6).map((comp, index) => (
          <div style="margin-bottom: 1rem;">
            <button 
              onclick={`window.setOpenCompo('${comp.id}')`}
              style="background: #333; padding: 1rem; border-radius: 8px; width: 100%; text-align: left; border: 1px solid #444; color: white; cursor: pointer; margin-bottom: 0.5rem;"
            >
              🔵 Abrir Opción 2 (ID: {comp.id})
            </button>
            <TestIOSReactOpcion2 comp={comp} client:load />
          </div>
        ))
      }
    </div>

    <!-- Prueba 9: OPCIÓN 3 (Puro React) -->
    <div class="test-box" style="margin-bottom: 2rem; border-top: 2px dashed #444; padding-top: 2rem;">
      <h2 style="color: #50fa7b; margin-bottom: 1rem;">Opción 3: Todo manejado por React</h2>
      <p style="color: #ccc; margin-bottom: 1rem;">Ni Astro ni HTML controlan los clics. Todo el bloque es un solo componente React gigante.</p>
      <TestIOSReactOpcion3 comps={todasLasCompsPBE.slice(6, 9)} client:load />
    </div>

  </div>
  </Main>

  <script is:inline>
    // Lógica para Test 1
    const header1 = document.getElementById('test1-header');
    const content1 = document.getElementById('test1-content');
    if (header1 && content1) {
      header1.addEventListener('click', () => {
        content1.style.display = content1.style.display === 'none' ? 'block' : 'none';
      });
    }

    // Lógica para Test 2
    const header2 = document.getElementById('test2-header');
    const content2 = document.getElementById('test2-content');
    if (header2 && content2) {
      header2.addEventListener('click', () => {
        content2.style.display = content2.style.display === 'none' ? 'block' : 'none';
      });
    }

    // Lógica para Test 3
    const header3 = document.getElementById('test3-header');
    const content3 = document.getElementById('test3-content');
    if (header3 && content3) {
      header3.addEventListener('click', () => {
        content3.style.display = content3.style.display === 'none' ? 'block' : 'none';
      });
    }
  </script>

  <script>
    import { activeCompId } from "@stores/menuFiltradoAdmin";
    import { setOpenCompo } from "@stores/openCompoById";
    
    // Expose for Option 2 (inline onclick)
    (window as any).setOpenCompo = setOpenCompo;

    // OPCIÓN 1: Limpiar listeners viejos y añadir uno seguro
    const btnsOp1 = document.querySelectorAll('.op1-btn');
    btnsOp1.forEach(btn => {
      // Clonar el nodo borra cualquier listener que tuviera antes (soluciona eventos fantasma en HMR)
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
      
      newBtn.addEventListener('click', () => {
        setOpenCompo((newBtn as HTMLElement).getAttribute('data-comp-id'));
      });
    });

    activeCompId.subscribe((id) => {
      const stringId = id ? String(id) : null;
      document.querySelectorAll(".op1-container").forEach((el) => {
        if (el.getAttribute("data-comp-id") === stringId) {
          el.classList.remove("hide");
          void (el as HTMLElement).offsetHeight; // Force reflow
        } else {
          el.classList.add("hide");
        }
      });
    });
  </script>

  <style>
    .hide { display: none !important; }
  </style>
</Layout>
